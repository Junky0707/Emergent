[
  {
    "name": "theme_info",
    "theme_name": "AURAVITA",
    "theme_version": "1.0.0",
    "theme_author": "Premium Theme Studio",
    "theme_documentation_url": "https://auravita-theme.com/docs",
    "theme_support_url": "https://auravita-theme.com/support"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 250,
        "step": 10,
        "unit": "px",
        "label": "Logo Width",
        "default": 130
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Brand Colors"
      },
      {
        "type": "color",
        "id": "color_brand_primary",
        "label": "Brand Primary",
        "default": "#2C3E30",
        "info": "Used for buttons, accents, and key UI elements"
      },
      {
        "type": "color",
        "id": "color_brand_secondary",
        "label": "Brand Secondary",
        "default": "#E7E5E4",
        "info": "Used for borders and subtle backgrounds"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent Color",
        "default": "#A8522E",
        "info": "Used for highlights and special elements"
      },
      {
        "type": "header",
        "content": "Background Colors"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#FAFAF9"
      },
      {
        "type": "color",
        "id": "color_background_subtle",
        "label": "Background Subtle",
        "default": "#F5F5F4"
      },
      {
        "type": "color",
        "id": "color_background_contrast",
        "label": "Background Contrast",
        "default": "#FFFFFF"
      },
      {
        "type": "header",
        "content": "Text Colors"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Primary Text",
        "default": "#1C1917"
      },
      {
        "type": "color",
        "id": "color_foreground_secondary",
        "label": "Secondary Text",
        "default": "#57534E"
      },
      {
        "type": "color",
        "id": "color_foreground_muted",
        "label": "Muted Text",
        "default": "#A8A29E"
      },
      {
        "type": "header",
        "content": "Utility Colors"
      },
      {
        "type": "color",
        "id": "color_success",
        "label": "Success",
        "default": "#3F6212"
      },
      {
        "type": "color",
        "id": "color_warning",
        "label": "Warning",
        "default": "#854D0E"
      },
      {
        "type": "color",
        "id": "color_error",
        "label": "Error",
        "default": "#991B1B"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "label": "Heading Font",
        "default": "playfair_display_n4"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body Font",
        "default": "dm_sans_n4"
      },
      {
        "type": "range",
        "id": "type_body_size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Body Font Size",
        "default": 16
      },
      {
        "type": "range",
        "id": "type_heading_scale",
        "min": 80,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading Scale",
        "default": 100
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 50,
        "unit": "px",
        "label": "Page Width",
        "default": 1400
      },
      {
        "type": "range",
        "id": "spacing_section",
        "min": 40,
        "max": 120,
        "step": 10,
        "unit": "px",
        "label": "Section Spacing",
        "default": 80
      },
      {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 24,
        "step": 2,
        "unit": "px",
        "label": "Border Radius",
        "default": 0,
        "info": "Applies to buttons, cards, and inputs"
      }
    ]
  },
  {
    "name": "Product Cards",
    "settings": [
      {
        "type": "checkbox",
        "id": "product_card_show_secondary_image",
        "label": "Show Secondary Image on Hover",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "product_card_show_vendor",
        "label": "Show Vendor",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "product_card_show_rating",
        "label": "Show Rating",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "product_card_enable_quick_add",
        "label": "Enable Quick Add",
        "default": true
      },
      {
        "type": "select",
        "id": "product_card_image_ratio",
        "label": "Image Ratio",
        "options": [
          { "value": "adapt", "label": "Adapt to Image" },
          { "value": "portrait", "label": "Portrait (3:4)" },
          { "value": "square", "label": "Square (1:1)" }
        ],
        "default": "portrait"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart Type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_show_shipping_bar",
        "label": "Show Free Shipping Progress Bar",
        "default": true
      },
      {
        "type": "range",
        "id": "cart_free_shipping_threshold",
        "min": 0,
        "max": 200,
        "step": 5,
        "unit": "$",
        "label": "Free Shipping Threshold",
        "default": 75
      },
      {
        "type": "checkbox",
        "id": "cart_enable_upsell",
        "label": "Enable Cart Upsell",
        "default": true
      },
      {
        "type": "product",
        "id": "cart_upsell_product",
        "label": "Upsell Product"
      }
    ]
  },
  {
    "name": "Product Page",
    "settings": [
      {
        "type": "checkbox",
        "id": "product_sticky_atc",
        "label": "Enable Sticky Add to Cart",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "product_show_subscription",
        "label": "Show Subscription Option",
        "default": true,
        "info": "Requires selling plans configured"
      },
      {
        "type": "range",
        "id": "product_subscription_discount",
        "min": 5,
        "max": 30,
        "step": 5,
        "unit": "%",
        "label": "Subscription Discount",
        "default": 15
      },
      {
        "type": "checkbox",
        "id": "product_show_inventory",
        "label": "Show Inventory Status",
        "default": true
      },
      {
        "type": "range",
        "id": "product_low_stock_threshold",
        "min": 1,
        "max": 20,
        "step": 1,
        "label": "Low Stock Threshold",
        "default": 10
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok"
      },
      {
        "type": "text",
        "id": "social_linkedin_link",
        "label": "LinkedIn"
      }
    ]
  },
  {
    "name": "SEO & Analytics",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_structured_data",
        "label": "Enable Structured Data (Schema.org)",
        "default": true
      },
      {
        "type": "textarea",
        "id": "google_analytics_id",
        "label": "Google Analytics 4 ID",
        "info": "Enter your GA4 Measurement ID (G-XXXXXXXXXX)"
      }
    ]
  }
]
