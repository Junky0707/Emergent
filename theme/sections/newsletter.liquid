<section class="newsletter" style="padding: 8rem 0; background: {{ settings.color_brand_primary }}; color: {{ settings.color_background }};">
  <div class="page-width" style="max-width: 60rem; text-align: center;">
    {%- if section.settings.subheading != blank -%}
      <span style="font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.15em; opacity: 0.7; margin-bottom: 1.5rem; display: block;">
        {{ section.settings.subheading }}
      </span>
    {%- endif -%}
    
    {%- if section.settings.heading != blank -%}
      <h2 style="font-size: clamp(2.8rem, 4vw, 3.5rem); margin-bottom: 1.5rem;">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    {%- if section.settings.text != blank -%}
      <p style="font-size: 1.6rem; opacity: 0.8; margin-bottom: 3rem;">{{ section.settings.text }}</p>
    {%- endif -%}
    
    {%- form 'customer', id: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div style="display: flex; flex-direction: column; gap: 1rem; max-width: 45rem; margin: 0 auto;">
        <style>
          @media (min-width: 750px) {
            .newsletter__form { flex-direction: row !important; }
          }
        </style>
        <div class="newsletter__form" style="display: flex; flex-direction: column; gap: 1rem;">
          <input
            type="email"
            name="contact[email]"
            placeholder="Enter your email"
            required
            style="flex: 1; background: transparent; border: none; border-bottom: 1px solid rgba(255,255,255,0.3); padding: 1.2rem 0; font-size: 1.6rem; color: inherit; outline: none;"
          >
          <button type="submit" class="button" style="background: {{ settings.color_background }}; color: {{ settings.color_foreground }}; white-space: nowrap;">
            Subscribe
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        </div>
      </div>
      <p style="font-size: 1.2rem; opacity: 0.6; margin-top: 2rem;">
        By subscribing, you agree to our Privacy Policy.
      </p>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Stay Connected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 15% Off Your First Order"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Join our community for exclusive offers, wellness tips, and early access to new products."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
