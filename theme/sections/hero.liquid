{%- comment -%}
  Hero Section - AURAVITA Theme
  Supports: Split layout, full-width, video background
{%- endcomment -%}

{%- style -%}
  #Hero-{{ section.id }} {
    min-height: {{ section.settings.hero_height | default: '100vh' }};
  }

  #Hero-{{ section.id }} .hero__content {
    {% case section.settings.content_position %}
      {% when 'top-left' %}
        align-items: flex-start;
        justify-content: flex-start;
      {% when 'top-center' %}
        align-items: flex-start;
        justify-content: center;
      {% when 'middle-left' %}
        align-items: center;
        justify-content: flex-start;
      {% when 'middle-center' %}
        align-items: center;
        justify-content: center;
      {% when 'bottom-left' %}
        align-items: flex-end;
        justify-content: flex-start;
    {% endcase %}
  }
{%- endstyle -%}

<section
  id="Hero-{{ section.id }}"
  class="hero hero--{{ section.settings.hero_layout }} color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
>
  {%- if section.settings.hero_layout == 'split' -%}
    <div class="hero__split">
      {%- comment -%} Content Side {%- endcomment -%}
      <div class="hero__content">
        <div class="hero__content-inner">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'badge' -%}
                <span class="hero__badge mono" {{ block.shopify_attributes }}>
                  {{ block.settings.badge_text }}
                </span>
              
              {%- when 'heading' -%}
                <h1 class="hero__heading h1" {{ block.shopify_attributes }}>
                  {{ block.settings.heading }}
                </h1>
              
              {%- when 'text' -%}
                <p class="hero__text body-large" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </p>
              
              {%- when 'buttons' -%}
                <div class="hero__buttons" {{ block.shopify_attributes }}>
                  {%- if block.settings.button_label_1 != blank -%}
                    <a
                      href="{{ block.settings.button_link_1 }}"
                      class="button button--{{ block.settings.button_style_1 }}"
                    >
                      {{ block.settings.button_label_1 }}
                      {%- render 'icon', icon: 'arrow-right' -%}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.button_label_2 != blank -%}
                    <a
                      href="{{ block.settings.button_link_2 }}"
                      class="button button--{{ block.settings.button_style_2 }}"
                    >
                      {{ block.settings.button_label_2 }}
                    </a>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}

          {%- comment -%} Trust Indicators {%- endcomment -%}
          {%- if section.settings.show_trust_indicators -%}
            <div class="hero__trust">
              {% render 'trust-indicator', icon: 'gmp', label: 'Certified' %}
              {% render 'trust-indicator', icon: '3p', label: 'Third-Party Tested' %}
              {% render 'trust-indicator', icon: '30', label: 'Day Guarantee' %}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Media Side {%- endcomment -%}
      <div class="hero__media">
        {%- if section.settings.video_url != blank -%}
          <video
            class="hero__video"
            autoplay
            muted
            loop
            playsinline
            poster="{{ section.settings.image | image_url: width: 1920 }}"
          >
            <source src="{{ section.settings.video_url }}" type="video/mp4">
          </video>
        {%- elsif section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1920
            | image_tag:
              class: 'hero__image',
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '(min-width: 1024px) 50vw, 100vw',
              widths: '375, 550, 750, 1000, 1250, 1500, 1750, 1920'
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder' }}
        {%- endif -%}
      </div>
    </div>
  {%- else -%}
    {%- comment -%} Full Width Layout {%- endcomment -%}
    <div class="hero__full">
      <div class="hero__media-overlay">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1920
            | image_tag:
              class: 'hero__image',
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '100vw',
              widths: '375, 550, 750, 1000, 1250, 1500, 1750, 1920'
          }}
        {%- endif -%}
      </div>
      <div class="hero__content page-width">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              <h1 class="hero__heading h1" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
              </h1>
            {%- when 'text' -%}
              <p class="hero__text body-large" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </p>
            {%- when 'buttons' -%}
              <div class="hero__buttons" {{ block.shopify_attributes }}>
                {%- if block.settings.button_label_1 != blank -%}
                  <a href="{{ block.settings.button_link_1 }}" class="button button--{{ block.settings.button_style_1 }}">
                    {{ block.settings.button_label_1 }}
                  </a>
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "select",
      "id": "hero_layout",
      "label": "Layout",
      "options": [
        { "value": "split", "label": "Split" },
        { "value": "full", "label": "Full Width" }
      ],
      "default": "split"
    },
    {
      "type": "select",
      "id": "hero_height",
      "label": "Section Height",
      "options": [
        { "value": "100vh", "label": "Full Screen" },
        { "value": "80vh", "label": "Large" },
        { "value": "60vh", "label": "Medium" }
      ],
      "default": "100vh"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL",
      "info": "Use MP4 format for best performance"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "options": [
        { "value": "top-left", "label": "Top Left" },
        { "value": "top-center", "label": "Top Center" },
        { "value": "middle-left", "label": "Middle Left" },
        { "value": "middle-center", "label": "Middle Center" },
        { "value": "bottom-left", "label": "Bottom Left" }
      ],
      "default": "middle-left"
    },
    {
      "type": "checkbox",
      "id": "show_trust_indicators",
      "label": "Show Trust Indicators",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "options": [
        { "value": "background", "label": "Background" },
        { "value": "background-contrast", "label": "Background Contrast" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "background"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "default": "Science-Backed Wellness"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "heading",
          "label": "Heading",
          "default": "<p>Elevate Your <em>Daily Ritual</em></p>"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Premium supplements and skincare formulated with clinically-proven ingredients.</p>"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "label": "First Button Label",
          "default": "Shop Collection"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "First Button Link"
        },
        {
          "type": "select",
          "id": "button_style_1",
          "label": "First Button Style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "primary"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Second Button Label",
          "default": "Our Science"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Second Button Link"
        },
        {
          "type": "select",
          "id": "button_style_2",
          "label": "Second Button Style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "secondary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "badge" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
