<section class="main-page" style="padding: 4rem 0;">
  <div class="page-width" style="max-width: 80rem;">
    <h1 style="font-size: clamp(3rem, 5vw, 4.5rem); margin-bottom: 3rem; text-align: center;">{{ page.title }}</h1>
    <div class="page-content" style="font-size: 1.6rem; line-height: 1.8; color: {{ settings.color_foreground_secondary }};">
      {{ page.content }}
    </div>
  </div>
</section>

<style>
  .page-content h2 { font-size: 2.4rem; margin: 3rem 0 1.5rem; color: var(--color-foreground); }
  .page-content h3 { font-size: 2rem; margin: 2.5rem 0 1rem; color: var(--color-foreground); }
  .page-content p { margin-bottom: 1.5rem; }
  .page-content ul, .page-content ol { margin-bottom: 1.5rem; padding-left: 2rem; }
  .page-content li { margin-bottom: 0.5rem; }
  .page-content a { color: var(--color-brand-primary); text-decoration: underline; }
</style>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "settings": []
}
{% endschema %}
