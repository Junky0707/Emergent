{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 4
-%}

<section class="featured-collection" style="padding: 8rem 0;">
  <div class="page-width">
    {%- comment -%} Header {%- endcomment -%}
    <div style="display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 2rem; margin-bottom: 4rem;">
      <div>
        {%- if section.settings.subheading != blank -%}
          <span style="font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.15em; color: {{ settings.color_brand_primary }}; margin-bottom: 1rem; display: block;">
            {{ section.settings.subheading }}
          </span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 style="font-size: clamp(2.8rem, 4vw, 4rem);">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
      {%- if collection != blank -%}
        <a href="{{ collection.url }}" style="font-size: 1.4rem; color: {{ settings.color_foreground }}; text-decoration: underline; text-underline-offset: 4px;">
          View All Products
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Products Grid {%- endcomment -%}
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem;">
      <style>
        @media (min-width: 750px) {
          .featured-collection .products-grid { grid-template-columns: repeat(3, 1fr) !important; }
        }
        @media (min-width: 990px) {
          .featured-collection .products-grid { grid-template-columns: repeat(4, 1fr) !important; }
        }
      </style>
      <div class="products-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; grid-column: 1 / -1;">
        {%- if collection != blank -%}
          {%- for product in collection.products limit: products_to_show -%}
            <article class="product-card" style="position: relative;">
              <a href="{{ product.url }}" style="display: block;">
                <div style="position: relative; aspect-ratio: 3/4; overflow: hidden; background: {{ settings.color_background_subtle }}; margin-bottom: 1.5rem;">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 600 | image_tag: 
                      style: 'width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;',
                      loading: 'lazy',
                      class: 'product-card__image'
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                  
                  {%- if product.available == false -%}
                    <span style="position: absolute; top: 1rem; left: 1rem; background: {{ settings.color_foreground }}; color: {{ settings.color_background }}; font-size: 1rem; padding: 0.4rem 1rem; text-transform: uppercase; letter-spacing: 0.1em;">
                      Sold Out
                    </span>
                  {%- elsif product.compare_at_price > product.price -%}
                    <span style="position: absolute; top: 1rem; left: 1rem; background: {{ settings.color_accent }}; color: {{ settings.color_background }}; font-size: 1rem; padding: 0.4rem 1rem; text-transform: uppercase; letter-spacing: 0.1em;">
                      Sale
                    </span>
                  {%- endif -%}
                </div>
                
                <div>
                  <span style="font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.1em; color: {{ settings.color_foreground_secondary }}; display: block; margin-bottom: 0.5rem;">
                    {{ product.type | default: 'Wellness' }}
                  </span>
                  <h3 style="font-size: 1.8rem; margin-bottom: 0.8rem;">{{ product.title }}</h3>
                  <div style="display: flex; align-items: center; gap: 1rem;">
                    <span style="font-size: 1.6rem; font-weight: 500;">{{ product.price | money }}</span>
                    {%- if product.compare_at_price > product.price -%}
                      <span style="font-size: 1.4rem; color: {{ settings.color_foreground_secondary }}; text-decoration: line-through;">
                        {{ product.compare_at_price | money }}
                      </span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            </article>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..products_to_show) -%}
            <article class="product-card">
              <div style="aspect-ratio: 3/4; background: {{ settings.color_background_subtle }}; margin-bottom: 1.5rem;"></div>
              <span style="font-size: 1.1rem; color: {{ settings.color_foreground_secondary }}; display: block; margin-bottom: 0.5rem;">Category</span>
              <h3 style="font-size: 1.8rem; margin-bottom: 0.8rem;">Product Title</h3>
              <span style="font-size: 1.6rem;">$0.00</span>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .product-card:hover .product-card__image {
    transform: scale(1.05);
  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our Collection"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Heading",
      "default": "<p>Curated for <em>You</em></p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
