{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 12
-%}

<section class="main-collection" style="padding: 4rem 0;">
  <div class="page-width">
    {%- comment -%} Collection Header {%- endcomment -%}
    <div style="text-align: center; margin-bottom: 4rem; padding: 4rem 0; background: {{ settings.color_background_subtle }}; margin: -4rem -1.5rem 4rem; padding: 6rem 1.5rem;">
      <h1 style="font-size: clamp(3rem, 5vw, 5rem); margin-bottom: 1.5rem;">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p style="font-size: 1.6rem; color: {{ settings.color_foreground_secondary }}; max-width: 60rem; margin: 0 auto;">
          {{ collection.description }}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} Toolbar {%- endcomment -%}
    <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 2rem; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid {{ settings.color_background_subtle }};">
      <span style="font-size: 1.4rem; color: {{ settings.color_foreground_secondary }};">
        {{ collection.products_count }} products
      </span>
      <div style="display: flex; align-items: center; gap: 1rem;">
        <label for="sort-by" style="font-size: 1.4rem;">Sort by:</label>
        <select id="sort-by" onchange="window.location.href = this.value" style="padding: 0.8rem 1.2rem; border: 1px solid {{ settings.color_background_subtle }}; border-radius: 4px; font-size: 1.4rem; background: transparent;">
          {%- for option in collection.sort_options -%}
            <option value="{{ option.url }}" {% if option.value == collection.sort_by %}selected{% endif %}>
              {{ option.name }}
            </option>
          {%- endfor -%}
        </select>
      </div>
    </div>

    {%- comment -%} Products Grid {%- endcomment -%}
    {%- paginate collection.products by products_per_page -%}
      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem;">
        <style>
          @media (min-width: 750px) {
            .collection-grid { grid-template-columns: repeat(3, 1fr) !important; }
          }
          @media (min-width: 990px) {
            .collection-grid { grid-template-columns: repeat(4, 1fr) !important; }
          }
        </style>
        <div class="collection-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; grid-column: 1 / -1;">
          {%- for product in collection.products -%}
            <article class="product-card" style="position: relative;">
              <a href="{{ product.url }}" style="display: block;">
                <div style="position: relative; aspect-ratio: 3/4; overflow: hidden; background: {{ settings.color_background_subtle }}; margin-bottom: 1.5rem;">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 600 | image_tag: 
                      style: 'width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;',
                      loading: 'lazy',
                      class: 'product-card__image'
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                  
                  {%- if product.available == false -%}
                    <span style="position: absolute; top: 1rem; left: 1rem; background: {{ settings.color_foreground }}; color: {{ settings.color_background }}; font-size: 1rem; padding: 0.4rem 1rem; text-transform: uppercase; letter-spacing: 0.1em;">
                      Sold Out
                    </span>
                  {%- elsif product.compare_at_price > product.price -%}
                    <span style="position: absolute; top: 1rem; left: 1rem; background: {{ settings.color_accent }}; color: {{ settings.color_background }}; font-size: 1rem; padding: 0.4rem 1rem; text-transform: uppercase; letter-spacing: 0.1em;">
                      Sale
                    </span>
                  {%- endif -%}
                </div>
                
                <div>
                  <span style="font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.1em; color: {{ settings.color_foreground_secondary }}; display: block; margin-bottom: 0.5rem;">
                    {{ product.type | default: 'Wellness' }}
                  </span>
                  <h3 style="font-size: 1.8rem; margin-bottom: 0.8rem;">{{ product.title }}</h3>
                  <div style="display: flex; align-items: center; gap: 1rem;">
                    <span style="font-size: 1.6rem; font-weight: 500;">{{ product.price | money }}</span>
                    {%- if product.compare_at_price > product.price -%}
                      <span style="font-size: 1.4rem; color: {{ settings.color_foreground_secondary }}; text-decoration: line-through;">
                        {{ product.compare_at_price | money }}
                      </span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            </article>
          {%- else -%}
            <p style="grid-column: 1 / -1; text-align: center; padding: 4rem; color: {{ settings.color_foreground_secondary }};">
              No products found in this collection.
            </p>
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} Pagination {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <nav style="margin-top: 4rem; display: flex; justify-content: center; gap: 0.5rem;">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" style="padding: 1rem 1.5rem; border: 1px solid {{ settings.color_background_subtle }}; border-radius: 4px;">←</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" style="padding: 1rem 1.5rem; border: 1px solid {{ settings.color_background_subtle }}; border-radius: 4px;">{{ part.title }}</a>
            {%- else -%}
              <span style="padding: 1rem 1.5rem; background: {{ settings.color_foreground }}; color: {{ settings.color_background }}; border-radius: 4px;">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" style="padding: 1rem 1.5rem; border: 1px solid {{ settings.color_background_subtle }}; border-radius: 4px;">→</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

<style>
  .product-card:hover .product-card__image {
    transform: scale(1.05);
  }
</style>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    }
  ]
}
{% endschema %}
